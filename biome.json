{
	"$schema": "https://biomejs.dev/schemas/latest/schema.json",

	"files": {
		"includes": ["**/*.{js,jsx,ts,tsx}", "!dist"]
	},

	"formatter": {
		"enabled": true
	},

	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},

	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	}
}
